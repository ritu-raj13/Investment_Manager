# ============================================================================
# Knowledge Base Configuration
# Copy these settings to your backend/.env file and adjust as needed
# ============================================================================

# ----------------------------------------------------------------------------
# LLM Configuration (Ollama)
# ----------------------------------------------------------------------------

# Ollama server URL (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# LLM model for text generation (chatbot responses, content analysis)
# Use the model you have installed in Ollama
# Check available models: ollama list
# Options: gpt-oss:20b, mistral, llama2, phi, etc.
OLLAMA_LLM_MODEL=gpt-oss:20b

# Temperature for LLM responses (0.0-1.0)
# Lower = more deterministic and factual
# Recommended for educational content: 0.1-0.3
LLM_TEMPERATURE=0.15

# Maximum tokens for LLM responses
# Higher = longer responses, but slower
LLM_MAX_TOKENS=500

# ----------------------------------------------------------------------------
# Embedding Configuration
# ----------------------------------------------------------------------------

# Embedding provider: 'ollama' or 'sentence-transformers'
# 'ollama' uses your local Ollama embedding model (faster, more consistent)
# 'sentence-transformers' uses HuggingFace models (may require download)
EMBEDDING_PROVIDER=ollama

# Ollama embedding model (only used if EMBEDDING_PROVIDER='ollama')
# Check available models: ollama list
# Recommended: nomic-embed-text:latest (good quality, fast)
OLLAMA_EMBEDDING_MODEL=nomic-embed-text:latest

# Sentence-transformers model (only used if EMBEDDING_PROVIDER='sentence-transformers')
# Options: all-MiniLM-L6-v2, all-mpnet-base-v2, etc.
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2

# ----------------------------------------------------------------------------
# Vector Database Configuration (ChromaDB)
# ----------------------------------------------------------------------------

# Directory for ChromaDB persistent storage
CHROMA_DB_DIR=chroma_db

# Collection name for trading notes
CHROMA_COLLECTION_NAME=trading_notes

# Number of results to retrieve for RAG (context chunks)
# Higher = more context, but may include irrelevant information
# Recommended: 3-7
RAG_TOP_K_RESULTS=5

# ----------------------------------------------------------------------------
# PDF Processing Configuration
# ----------------------------------------------------------------------------

# Directory for uploaded PDFs
PDF_UPLOAD_DIR=uploads/pdfs

# Text chunking parameters
# CHUNK_SIZE: Characters per chunk (larger = more context per chunk)
# CHUNK_OVERLAP: Overlap between chunks (prevents context loss at boundaries)
CHUNK_SIZE=500
CHUNK_OVERLAP=100

# ----------------------------------------------------------------------------
# Content Organization Configuration
# ----------------------------------------------------------------------------

# Maximum number of proposals to generate per document
MAX_PROPOSALS_PER_DOC=10

# Temperature for content organization analysis
# Higher = more creative organization suggestions
ORGANIZATION_TEMPERATURE=0.2

# ----------------------------------------------------------------------------
# Performance Configuration
# ----------------------------------------------------------------------------

# Request timeout for Ollama in seconds
# Larger models or complex queries may need more time
OLLAMA_TIMEOUT=120

# Enable verbose logging (true/false)
# Set to 'true' for debugging
VERBOSE_LOGGING=false

# ============================================================================
# Quick Configuration Guide
# ============================================================================
#
# For your setup with:
# - gpt-oss:20b (LLM)
# - nomic-embed-text:latest (embeddings)
#
# Recommended configuration:
#
# OLLAMA_LLM_MODEL=gpt-oss:20b
# EMBEDDING_PROVIDER=ollama
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text:latest
# LLM_TEMPERATURE=0.15
# RAG_TOP_K_RESULTS=5
#
# ============================================================================

